{
  "expo": {
    "name": "AI Studio Pro",
    "slug": "ai-studio-pro",
    "owner": "carlosbritocvs-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aistudiopro.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.aistudiopro.app",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "AI Studio Pro accederá a tus fotos para editarlas.",
          "cameraPermission": "AI Studio Pro accederá a tu cámara para capturar fotos y vídeos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permite guardar tus creaciones en la galería.",
          "savePhotosPermission": "Permite guardar imágenes y vídeos en tu galería.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "scheme": "ai-studio-pro",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "baf2e0e6-b20f-41c9-9ad9-fee63cbd82d8"
      }
    }
  }
}
